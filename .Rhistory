P <- matrix(c(0.7, 0.3,
0.4, 0.6),
2, 2, byrow = TRUE)
state <- Re(eigen(t(P))$vectors[,1])
state <- state / sum(state)
cat("Stationary Distribution:", state, "\n")
# Creating Employee Data Frame
employee_data <- data.frame(
emp_id = c(101,102,103,104,105),
name = c("Chandra","Sujoy","John","Rakesh","Silpa"),
depart = c("HR","IT","Finance","IT","HR"),
salary = c(35000,45000,40000,50000,38000),
experience = c(2,3,5,6,3)
)
# Display the data frame
print("Employee Data")
print(employee_data)
# Access First row
print(employee_data[1,])
# Access salary column
print(employee_data$salary)
# Access specific element (Row 2, Column 4)
print(employee_data[2,4])
# Employees with salary greater than 40000
high_salary <- subset(employee_data, salary > 40000)
print("Employees with salary > 40000")
print(high_salary)
# Employee from IT Department
it_employees <- subset(employee_data, depart == "IT")
print("IT Department Employees")
print(it_employees)
# Add a new column Bonus
employee_data$Bonus <- employee_data$salary * 0.10
# Increase salary by 15000
employee_data$salary <- employee_data$salary + 15000
# Update salary of first employee
employee_data$salary[1] <- 50000
# Remove Experience Column
employee_data$experience <- NULL
print("Manipulated Employee Data")
print(employee_data)
# Average Salary
mean(employee_data$salary)
# Maximum and Minimum Salary
max(employee_data$salary)
min(employee_data$salary)
# Summary of dataset
summary(employee_data)
