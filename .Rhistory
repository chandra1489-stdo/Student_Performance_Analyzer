# Data
x <- c(10,20,30,40,50)
y <- c(5,10,15,20,25)
marks <- c(65,70,75,80,85)
subjects <- c("Math","R","OSC","DS","Eng")
scores <- c(85,90,78,88,92)
# Plot (Basic Plot)
plot(x,y,
main="Basic Plot",
xlab="X values",
ylab="Y values",
col="blue",
pch=19)
# Histogram Chart
hist(marks,
main="Histogram of Marks",
xlab="Marks",
col="green",
border="black")
# Line Chart
plot(x,y,
type="l",
main="Line Chart",
xlab="X values",
ylab="Y values",
col="red",
lwd=2)
# Pie Chart
pie(scores,
labels=subjects,
main="Pie Chart of Subject Scores",
col=rainbow(length(scores)))
# Box Plot
boxplot(marks,
main="BoxPlot of Marks",
col="orange",
horizontal=TRUE)
# Scatter Plot
plot(x,y,
main="Scatter Plot",
xlab="X values",
ylab="Y values",
col="purple",
pch=16)
