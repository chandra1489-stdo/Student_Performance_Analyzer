# Define a function with default arguments and returning a complex object
generate_summary <- function(data = rnorm(100), summary_type = "basic")
{
{
{
# Compute the summary based on the summary_type
if (summary_type == "basic")
result <- list(
mean = mean(data),
median = median(data),
sd = sd(data)
)
} else if (summary_type == "detailed")
generate_summary <- function(data = rnorm(100), summary_type = "basic")
{
if (summary_type == "basic") {
result <- list(
mean = mean(data),
median = median(data),
sd = sd(data)
)
} else if (summary_type == "detailed") {
result <- list(
mean = mean(data),
median = median(data),
sd = sd(data),
variance = var(data),
range = range(data),
quantiles = quantile(data)
)
} else {
stop("Invalid summary_type. Use 'basic' or 'detailed'.")
}
return(result)
}
set.seed(42)
data <- rnorm(50, mean = 10, sd = 2)
default_summary <- generate_summary()
custom_summary <- generate_summary(data = data, summary_type = "detailed")
print("Default Summary:")
print(default_summary)
print("Custom Summary:")
print(custom_summary)
